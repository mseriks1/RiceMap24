RICEMAP_ENV=staging
RICEMAP_DEBUG=0
RICEMAP_DEPLOYMENT_PROVIDER=render
RICEMAP_DEPLOYMENT_REGION=frankfurt
RICEMAP_RELEASE_VERSION=step9.40-production-prelaunch
RICEMAP_GIT_COMMIT_SHA=
PORT=8091

RICEMAP_DATA_DIR=/var/data
DATABASE_URL=sqlite:////var/data/ricemap24.sqlite3
DATABASE_SSL=false
CORS_ALLOWED_ORIGINS=https://staging.ricemap24.com
RICEMAP_PUBLIC_BASE_URL=https://staging.ricemap24.com
RICEMAP_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
RICEMAP_ADMIN_KEY=
RICEMAP_ENABLE_LEGACY_ADMIN_KEY=false

# Keep false for realistic staging. Set true only when you intentionally want demo kitchens.
ENABLE_DEMO_SEED=false
RICEMAP_UPLOAD_STORAGE=local
RICEMAP_UPLOADS_DIR=/var/data/uploads
RICEMAP_UPLOAD_MAX_MB=10

RICEMAP_STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe test price IDs, start with NOK for first checkout test.
STRIPE_PRICE_BASIC_MONTHLY_NOK=
STRIPE_PRICE_BUSINESS_MONTHLY_NOK=
STRIPE_PRICE_GROWTH_MONTHLY_NOK=
STRIPE_PRICE_PRO_MONTHLY_NOK=
STRIPE_PRICE_BASIC_YEARLY_NOK=
STRIPE_PRICE_BUSINESS_YEARLY_NOK=
STRIPE_PRICE_GROWTH_YEARLY_NOK=
STRIPE_PRICE_PRO_YEARLY_NOK=

RICEMAP_BACKUP_CONFIGURED=false
RICEMAP_ERROR_MONITORING_CONFIGURED=false
RICEMAP_ERROR_LOG_CONFIGURED=false
RICEMAP_REQUEST_LOGGING_ENABLED=true
RICEMAP_LOG_LEVEL=INFO
RICEMAP_ERROR_LOG_RETENTION_DAYS=30

# Backups
RICEMAP_BACKUP_DIR=/var/data/backups
RICEMAP_BACKUP_UPLOADS=true
