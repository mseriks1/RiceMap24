# RiceMap24 local development
RICEMAP_ENV=development
# Optional: set this to keep database/uploads/backups outside the code folder.
# Example on Mac: RICEMAP_DATA_DIR=/Users/yourname/RiceMap24-data
RICEMAP_DATA_DIR=
DATABASE_URL=
RICEMAP_ADMIN_KEY=admin
RICEMAP_ENABLE_LEGACY_ADMIN_KEY=true
RICEMAP_SESSION_SECRET=dev-only-change-before-production
CORS_ALLOWED_ORIGINS=
# Set false when you want an empty local database without demo kitchens.
ENABLE_DEMO_SEED=true
DATABASE_SSL=false

# Upload/image storage
RICEMAP_UPLOAD_STORAGE=local
# Use a persistent absolute path in staging/production, not a temporary deploy folder.
# Leave empty to use $RICEMAP_DATA_DIR/uploads when RICEMAP_DATA_DIR is set.
RICEMAP_UPLOADS_DIR=
RICEMAP_UPLOAD_MAX_MB=10

# Stripe later
RICEMAP_STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs. Configure one Price per plan/billing/currency.
# Legacy global values still work as fallback, but per-currency values are production-safe.
STRIPE_PRICE_BASIC_MONTHLY_NOK=
STRIPE_PRICE_BASIC_YEARLY_NOK=
STRIPE_PRICE_BUSINESS_MONTHLY_NOK=
STRIPE_PRICE_BUSINESS_YEARLY_NOK=
STRIPE_PRICE_GROWTH_MONTHLY_NOK=
STRIPE_PRICE_GROWTH_YEARLY_NOK=
STRIPE_PRICE_PRO_MONTHLY_NOK=
STRIPE_PRICE_PRO_YEARLY_NOK=
# Repeat for SEK, DKK, EUR, GBP, USD and CHF before production launch.

# Auth/session cookie is created by the app. Cookie name is fixed unless changed in code.
# RICEMAP_SESSION_COOKIE_NAME=ricemap24_session

# Production security/readiness
RICEMAP_PUBLIC_BASE_URL=https://ricemap24.com
RICEMAP_REQUIRE_HTTPS=1
RICEMAP_BACKUP_CONFIGURED=false
RICEMAP_ERROR_MONITORING_CONFIGURED=false
RICEMAP_ERROR_LOG_CONFIGURED=false
RICEMAP_REQUEST_LOGGING_ENABLED=true
RICEMAP_LOG_LEVEL=INFO
RICEMAP_ERROR_LOG_RETENTION_DAYS=30


# Email provider config. Use manual/queue-only until DNS/provider is ready.
RICEMAP24_EMAIL_PROVIDER=manual
RICEMAP24_EMAIL_DELIVERY_ENABLED=false
RICEMAP24_EMAIL_FROM_NAME=RiceMap24
RICEMAP24_EMAIL_FROM=no-reply@ricemap24.com
RICEMAP24_EMAIL_REPLY_TO=no-reply@ricemap24.com
RICEMAP24_ADMIN_NOTIFICATION_EMAIL=admin@ricemap24.com
RICEMAP24_EMAIL_DNS_VERIFIED=false
# For SMTP only:
RICEMAP24_SMTP_HOST=
RICEMAP24_SMTP_PORT=587
RICEMAP24_SMTP_USERNAME=

# Email provider secrets (admin settings choose manual/smtp/sendgrid/postmark)
# Keep real secrets out of zip/code. Use server environment variables.
RICEMAP24_SMTP_PASSWORD=
RICEMAP24_SENDGRID_API_KEY=
RICEMAP24_POSTMARK_SERVER_TOKEN=

# Deployment/runtime identity
RICEMAP_DEPLOYMENT_PROVIDER=local
RICEMAP_DEPLOYMENT_REGION=local
RICEMAP_RELEASE_VERSION=step9.40-production-prelaunch
RICEMAP_GIT_COMMIT_SHA=
PORT=8091

# Backups
# Leave empty to use $RICEMAP_DATA_DIR/backups when RICEMAP_DATA_DIR is set.
RICEMAP_BACKUP_DIR=
RICEMAP_BACKUP_UPLOADS=true
